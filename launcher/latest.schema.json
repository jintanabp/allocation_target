{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TargetAllocation Update Manifest",
  "type": "object",
  "required": ["version", "url", "sha256"],
  "properties": {
    "version": { "type": "string", "description": "Semver-like version (e.g. 1.2.3)" },
    "url": { "type": "string", "description": "HTTPS URL to the package zip" },
    "sha256": { "type": "string", "description": "SHA-256 hex of the zip content" },
    "notes": { "type": "string" }
  }
}

