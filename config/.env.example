# Copy to: config/.env
# Notes:
# - Do NOT commit real secrets.
# - backend will load `config/.env` first, then `.env` at repo root (root overrides).
#
# ── Microsoft Fabric / Power BI ───────────────────────────
FABRIC_TENANT_ID=
FABRIC_CLIENT_ID=
FABRIC_DATASET_ID=
FABRIC_WORKSPACE_ID=
FABRIC_CLIENT_SECRET=
#
# ── Entra (Microsoft login for this app) ──────────────────
# If AZURE_AUTH_CLIENT_ID is set, the frontend will require Microsoft login.
AZURE_AUTH_CLIENT_ID=
AZURE_AUTH_TENANT_ID=
AZURE_AUTH_ALLOWED_GROUP_ID=
# Set to 1 to disable Entra login requirement (dev only)
AZURE_AUTH_DISABLED=0
#
# ── Optional settings ─────────────────────────────────────
MANAGERS_CACHE_TTL_SEC=86400
ENABLE_DEBUG_ENDPOINTS=0
USE_LEGACY_TARGET_CSV=0
LP_HIST_ANCHOR=0.15
#
# ── Fabric schema overrides (only if your model differs) ──
TGA_TABLE_NAME=tga_target_salesman_next
TGA_COL_SALESMAN=SALESMANCODE
TGA_COL_PRODUCT=PRODUCTCODE
TGA_COL_QUANTITY=QUANTITYCASE
TGA_COL_EFFECTIVE=EFFECTIVEDATE
TGA_FILTER_BY_EFFECTIVE=0

