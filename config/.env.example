# Copy to: config/.env
# Notes:
# - Do NOT commit real secrets.
# - backend will load `config/.env` first, then `.env` at repo root (root overrides).

# ── Microsoft Fabric / Power BI ───────────────────────────
FABRIC_TENANT_ID=
FABRIC_CLIENT_ID=
FABRIC_DATASET_ID=
FABRIC_WORKSPACE_ID=
FABRIC_CLIENT_SECRET=

# ── Entra (Microsoft login for this app) ──────────────────
# If AZURE_AUTH_CLIENT_ID is set, the frontend will require Microsoft login.
# Permissions are resolved via config/user_access.json EMAIL + USERPL — not Fabric ACC_USER_CONTROL.
AZURE_AUTH_CLIENT_ID=
AZURE_AUTH_TENANT_ID=

# ── Deprecated (no longer enforced; kept for old .env compatibility) ──
# AZURE_AUTH_ALLOWED_GROUP_ID=

# Set to 1 to disable Entra login requirement (dev only)
AZURE_AUTH_DISABLED=0

# อีเมลแอดมิน — หน้า「จัดการสิทธิ์」+ เห็นทุกรหัส SL + ส่ง Target Sun
ALLOCATION_ADMIN_EMAILS=

# ── สิทธิ์ผู้ใช้ (แทน ACC_USER_CONTROL / acc_extra_user บน Fabric) ──
USER_ACCESS_JSON_PATH=config/user_access.json
USER_ACCESS_CACHE_TTL_SEC=300
EXTRA_USER_ACCESS_DISABLED=1

# Cache user_access / managers (local JSON — ไม่ดึงจาก Fabric)
USER_ACCESS_CACHE_TTL_SEC=300
MANAGERS_CACHE_TTL_SEC=86400
# Cache ผล GET /data/employees ต่อ (SL, งวด) — ลดการยิง DAX ซ้ำเมื่อสลับมุมมอง (0=ปิด)
EMPLOYEE_PAYLOAD_CACHE_TTL_SEC=900
# Cache รายชื่อพนักงานในหน้าแอดมิน (ว่าง = ใช้ค่า EMPLOYEE_PAYLOAD_CACHE_TTL_SEC)
# ADMIN_TEAM_CACHE_TTL_SEC=900
ENABLE_DEBUG_ENDPOINTS=0
USE_LEGACY_TARGET_CSV=0
LP_HIST_ANCHOR=0.15

# ── Fabric schema overrides (only if your model differs) ──
TGA_TABLE_NAME=tga_target_salesman_next
TGA_COL_SALESMAN=SALESMANCODE
TGA_COL_PRODUCT=PRODUCTCODE
TGA_COL_QUANTITY=QUANTITYCASE
TGA_COL_EFFECTIVE=EFFECTIVEDATE
# เมื่อ MAX(EFFECTIVEDATE) ว่างทั้งตาราง — ใช้ MAX(col) นี้แทนในการคำนวณงวด snapshot (ปกติ UPDATEDATE)
# ตั้งเป็นค่าว่าง TGA_COL_EFFECTIVE_FALLBACK= เพื่อปิด fallback (เหมือนพฤติกรรมเก่าทั้งหมด)
TGA_COL_EFFECTIVE_FALLBACK=UPDATEDATE
# แอปบังคับกรองตาม EFFECTIVEDATE ในโค้ดแล้ว — ค่านี้ไม่ปิดการกรอง (เก็บไว้เพื่อความเข้ากันได้)
TGA_FILTER_BY_EFFECTIVE=0
# งวดเป้าที่ implied จาก MAX(EFFECTIVEDATE) (หรือ fallback): same = เดือนเดียวกัน (ค่าเริ่มต้น); next = เดือนถัดไป (พฤติกรรมเก่า)
TGA_EFFECTIVE_IMPLIED_TARGET=same
# 1 = บล็อกงวดเป้าที่เลือกถ้าน้อยกว่างวดที่ snapshot TGA รองรับ
TGA_ENFORCE_EFFECTIVE_WINDOW=1

# ── OneLake / Lakehouse upload (optional) ─────────────────
# ใช้ FABRIC_TENANT_ID / FABRIC_CLIENT_ID / FABRIC_CLIENT_SECRET ขอ token (storage scope) เพื่ออัปโหลดไฟล์เข้า OneLake
# ต้องเป็น GUID (รูปแบบ xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx) เท่านั้น — อย่าใส่ชื่อ Workspace/Lakehouse;
# ถ้าได้ error FriendlyNameSupportDisabled แปลว่าต้องเปลี่ยนจากชื่อเป็นค่า Id จาก Fabric URL / Properties
ONELAKE_WORKSPACE_ID=
ONELAKE_LAKEHOUSE_ID=
# โฟลเดอร์ปลายทางใน Lakehouse (ภายใต้ Files/)
ONELAKE_UPLOAD_DIR=Files/target_allocation_uploads
# คอลัมน์ dim ใน semantic model สำหรับ export รูปแบบ TGA (ให้ตรงกับตารางเป้าใน Power BI)
LAKEHOUSE_COL_SALESTYPE=SALESTYPE
LAKEHOUSE_COL_DIVISION=DIVISIONCODE
LAKEHOUSE_COL_AREACODE=AREACODE
LAKEHOUSE_COL_PROVINCE=PROVINCECODE
LAKEHOUSE_COL_WAREHOUSE=WAREHOUSECODE
# หลัง GET /data/employees จะสร้าง data/tga_lines_{sup}_{ปี}_{เดือน}.csv จาก tga_target_salesman_next (grain เต็ม) — ใช้แตกบรรทัด Excel TGA
# SALESTYPE / DIVISIONCODE ว่างได้ถ้า TGA ไม่มีค่า — USERCODE ส่งจากแอป (รหัส manager หรือ supervisor)

# ── TargetSun — ส่ง Excel TGA เข้า Oracle ผ่าน SPC API (UAT ชี้ Oracle 10.109.9.41 / service db01 ฝั่ง spc)
# ค่าเริ่มต้น = UAT ตาม targetsun-importTargetSalesmanNextFromExcel.md
TARGETSUN_IMPORT_EXCEL_URL=https://spcuatws.sahapat.com/spc/targetsun/importTargetSalesmanNextFromExcel
TARGETSUN_IMPORT_TIMEOUT_SEC=600
# เซิร์ฟวิทย์ภายใน — ถ้า SSL มีปัญหา: TARGETSUN_IMPORT_VERIFY_SSL=0 (ไม่แนะนำ production)
# TARGETSUN_IMPORT_VERIFY_SSL=1
# ถ้า API ต้องการ header (เช่น Bearer): ใส่ทั้งบรรทัดหรือแค่ token
# TARGETSUN_IMPORT_AUTH_HEADER=
